[sub_resource type="GDScript" id="GDScript_yehg7"]
script/source = "extends Node2D

@onready var xp_orb_scene = preload(\"res://Features/Cem/XPSystem/Scenes/xp_orb.tscn\")
@onready var game_over_screen = $GameOver
@onready var score = $GameUI/Score
func _ready():
	# Event Bus'ı dinlemeye başla
	EventBus.request_xp_spawn.connect(_on_xp_spawn_requested)
	EventBus.player_died.connect(_on_player_died)
	
	
func _on_player_died():
	# Game Over ekranını çağır ve skoru gönder
	game_over_screen.show_game_over(score.text)

func _on_xp_spawn_requested(pos: Vector2, amount: int):

	# XP Topunu oluştur
	for i in amount:
		var xp_instance = xp_orb_scene.instantiate()
		xp_instance.global_position = pos
		call_deferred(\"add_child\", xp_instance)
	# Pozisyonu ayarla
	
	
	# XP miktarını ayarla (XPOrb scriptinde bu değişken olmalı)
	#xp_instance.xp_amount = amount 
	
	# Sahneye ekle (Main node'un altına ekler)
	# call_deferred, fizik motoru çalışırken çakışma olmasın diye güvenlidir
	
"

